# =========================================================
# Seleksi Platform v2.3 - ENV MUDAH INSTALL
# =========================================================
# Urutan instalasi dari root project:
# 1) npm install
# 2) cp .env.example .env
# 3) nano .env
# 4) isi DATABASE_URL, AUTH_SECRET, BLOB_READ_WRITE_TOKEN bila dipakai
# 5) npx prisma generate
# 6) npx prisma migrate deploy
# 7) npm run db:seed
# 8) npm run dev

# WAJIB: URL database PostgreSQL.
# Contoh lokal:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/seleksi_platform?schema=public"
# Contoh Neon/Supabase: salin connection string PostgreSQL dari dashboard database.
DATABASE_URL=""

# WAJIB: minimal 32 karakter.
# Bisa dibuat otomatis dengan: npm run secret
AUTH_SECRET=""

# OPSIONAL: token Vercel Blob / penyimpanan aset. Boleh dikosongkan dulu jika belum pakai upload aset.
BLOB_READ_WRITE_TOKEN=""

# URL aplikasi lokal.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3000"
NEXT_PUBLIC_EXAM_URL="http://localhost:3001"
NEXT_PUBLIC_PENGAWAS_URL="http://localhost:3002"

# Akun admin pertama yang dibuat saat menjalankan: npm run db:seed
ADMIN_EMAIL="admin@seleksi.id"
ADMIN_PASSWORD="Admin12345!"
ADMIN_NAME="Super Admin"

# Supabase Storage opsional. Boleh dikosongkan jika belum dipakai.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="question-assets"
